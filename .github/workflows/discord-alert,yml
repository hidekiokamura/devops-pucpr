name: Alertas do Discord

on:
  push:
    branches:
      - main

jobs:
  enviar_alerta:
    runs-on: ubuntu-latest
    steps:
      - name: Disparar mensagem via Webhook
        run: |
          RESPONSE=$(curl -s -o /dev/null -w "%{http_code}" -H "Content-Type: application/json" \
          -d '{"content": "🚀 **Atividade Concluída!** O GitHub Actions enviou este alerta com sucesso para o canal."}' \
          ${{ secrets.DISCORD_WEBHOOK_URL }})
          
          if [ "$RESPONSE" -eq 204 ] || [ "$RESPONSE" -eq 200 ]; then
            echo "Mensagem enviada com sucesso!"
          else
            echo "Erro ao enviar: Código HTTP $RESPONSE"
            exit 1
          fi
